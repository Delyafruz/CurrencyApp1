@page "/crypto"
@inject CryptoService CryptoService

<PageTitle>Криптовалюты — CurrencyRates</PageTitle>

<!-- Заголовок -->
<div class="d-flex align-center gap-3 mb-1">
    <MudText Typo="Typo.h4" Style="font-weight:700;">Криптовалюты</MudText>
    <span style="font-size:2rem;">₿</span>
</div>
<MudText Typo="Typo.body2" Class="mb-4" Style="color:#666;">
    Актуальные цены в <strong>USD</strong> и <strong>тенге (₸)</strong>. Данные: CoinGecko.
</MudText>

<!-- Кнопка обновить -->
<MudPaper Class="pa-4 mb-4" Elevation="2" Style="border-radius:12px;">
    <div class="d-flex align-center gap-4 flex-wrap">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   OnClick="LoadRates"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   Disabled="@(_loading || _cooldown > 0)"
                   Style="border-radius:8px; min-width:160px;">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
                <span>Загрузка...</span>
            }
            else if (_cooldown > 0)
            {
                <span>Подождите @_cooldown сек</span>
            }
            else
            {
                <span>Обновить</span>
            }
        </MudButton>

        @if (_cooldown > 0)
        {
            <MudProgressLinear Value="@(100 - _cooldown * 100 / 30)"
                               Color="Color.Warning"
                               Style="width:120px; border-radius:4px;" />
        }

        @if (_lastUpdated != null)
        {
            <MudText Typo="Typo.body2" Style="color:#666;">
                Обновлено: <strong>@_lastUpdated</strong>
            </MudText>
        }
    </div>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Color="Color.Warning" Indeterminate="true" Class="mb-3" />
}

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="() => _error = null">
        @_error
    </MudAlert>
}

<!-- Карточки криптовалют -->
@if (_rates.Any())
{
    <MudGrid Spacing="4">
        @foreach (var coin in _rates)
        {
            var color = CryptoService.CryptoColors.GetValueOrDefault(coin.Id, "#888");
            var isUp = coin.Change24h >= 0;

            <MudItem xs="12" sm="6" md="6" lg="3">
                <MudPaper Elevation="3" Style="@($"border-radius:16px; overflow:hidden; border-top: 4px solid {color};")" Class="pa-0">

                    <!-- Шапка карточки -->
                    <div style="@($"background: linear-gradient(135deg, {color}22, {color}11); padding: 20px 20px 12px;")" class="d-flex align-center gap-3">
                        <div style="@($"background:{color}; color:white; width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.1rem; font-weight:800;")">
                            @coin.Icon
                        </div>
                        <div>
                            <MudText Typo="Typo.h6" Style="font-weight:700; line-height:1.2;">@coin.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Style="@($"background:{color}22; color:{color}; font-weight:700; height:20px;")">
                                @coin.Symbol
                            </MudChip>
                        </div>
                    </div>

                    <!-- Цены -->
                    <div style="padding: 16px 20px;">

                        <!-- Цена в USD -->
                        <div class="mb-3">
                            <MudText Typo="Typo.caption" Style="color:#999; text-transform:uppercase; letter-spacing:1px;">
                                1 @coin.Symbol = (USD)
                            </MudText>
                            <MudText Typo="Typo.h5" Style="font-weight:800; font-family:monospace;">
                                $@FormatPrice(coin.PriceUsd)
                            </MudText>
                        </div>

                        <MudDivider />

                        <!-- Цена в тенге -->
                        <div class="mt-3 mb-3">
                            <MudText Typo="Typo.caption" Style="color:#999; text-transform:uppercase; letter-spacing:1px;">
                                1 @coin.Symbol = (KZT)
                            </MudText>
                            <MudText Typo="Typo.h6" Style="font-weight:700; font-family:monospace; color:#1565c0;">
                                ₸@FormatPrice(coin.PriceKzt)
                            </MudText>
                        </div>

                        <MudDivider />

                        <!-- Изменение 24ч -->
                        <div class="mt-3 d-flex align-center justify-space-between">
                            <MudText Typo="Typo.caption" Style="color:#999;">За 24 часа</MudText>
                            <MudChip T="string"
                                     Color="@(isUp ? Color.Success : Color.Error)"
                                     Size="Size.Small"
                                     Icon="@(isUp ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)"
                                     Style="font-weight:700; font-family:monospace;">
                                @(isUp ? "+" : "")@coin.Change24h.ToString("F2")%
                            </MudChip>
                        </div>

                        <!-- Объём торгов -->
                        <div class="mt-2 d-flex align-center justify-space-between">
                            <MudText Typo="Typo.caption" Style="color:#999;">Объём 24ч</MudText>
                            <MudText Typo="Typo.caption" Style="font-family:monospace; color:#555;">
                                $@FormatLargeNumber(coin.Volume24hUsd)
                            </MudText>
                        </div>

                        <!-- Капитализация -->
                        <div class="mt-1 d-flex align-center justify-space-between">
                            <MudText Typo="Typo.caption" Style="color:#999;">Капитализация</MudText>
                            <MudText Typo="Typo.caption" Style="font-family:monospace; color:#555;">
                                $@FormatLargeNumber(coin.MarketCapUsd)
                            </MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

<MudText Typo="Typo.caption" Class="mt-4 d-block text-center" Style="color:#aaa;">
    Источник: <a href="https://www.coingecko.com" target="_blank">CoinGecko</a> — бесплатный API.
    Курс USD→KZT: <a href="https://nationalbank.kz" target="_blank">НБ РК</a>.
</MudText>

@code {
    private List<CryptoRate> _rates = new();
    private bool _loading = false;
    private string? _error;
    private string? _lastUpdated;
    private int _cooldown = 0;
    private System.Threading.CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        await LoadRates();
    }

    private async Task LoadRates()
    {
        if (_loading || _cooldown > 0) return;

        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _rates = await CryptoService.GetCryptoRatesAsync();
            _lastUpdated = DateTime.Now.ToString("HH:mm:ss");

            if (!_rates.Any())
                _error = "Данные не получены. Попробуйте позже.";
        }
        catch (Exception ex)
        {
            _error = $"Ошибка загрузки: {ex.Message}";
        }
        finally
        {
            _loading = false;
            // Запускаем кулдаун 30 секунд
            _ = StartCooldownAsync(30);
        }
    }

    private async Task StartCooldownAsync(int seconds)
    {
        _cts?.Cancel();
        _cts = new System.Threading.CancellationTokenSource();
        var token = _cts.Token;

        _cooldown = seconds;
        while (_cooldown > 0 && !token.IsCancellationRequested)
        {
            StateHasChanged();
            await Task.Delay(1000);
            _cooldown--;
        }
        _cooldown = 0;
        StateHasChanged();
    }

    // Форматирование цены: 1 234 567.89
    private string FormatPrice(decimal price)
    {
        if (price >= 1000)
            return price.ToString("N2");
        if (price >= 1)
            return price.ToString("N4");
        return price.ToString("N6");
    }

    // Форматирование больших чисел: 1.2B, 345M
    private string FormatLargeNumber(decimal num)
    {
        if (num >= 1_000_000_000)
            return $"{(num / 1_000_000_000):F1}B";
        if (num >= 1_000_000)
            return $"{(num / 1_000_000):F1}M";
        if (num >= 1_000)
            return $"{(num / 1_000):F1}K";
        return num.ToString("F0");
    }
}
