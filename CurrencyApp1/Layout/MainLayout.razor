@inherits LayoutComponentBase
@namespace CurrencyApp1.Layout

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="4" Style="background: linear-gradient(135deg, #1a237e 0%, #283593 50%, #1565c0 100%);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2" Style="font-weight:700; letter-spacing:1px;">
            💱 CurrencyRates
        </MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.7);">
            НБ РК · CoinGecko
        </MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="3" Variant="DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Навигация</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Home">
                Главная
            </MudNavLink>
            <MudNavLink Href="/rates"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.TableChart">
                Курсы валют НБ РК
            </MudNavLink>
            <MudNavLink Href="/crypto"
                        Match="NavLinkMatch.Prefix"
                        Icon="@Icons.Material.Filled.CurrencyBitcoin">
                Криптовалюты
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1565c0",
            Secondary = "#00897b",
            Background = "#f5f7fa",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
        }
    };
}
